# ============================================================
# AGSTC Backend - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.
# ============================================================

# Server port
PORT=5000

# Node environment (development | production)
NODE_ENV=production

# JWT secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# MySQL Database (Hostinger / PlanetScale / Render MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=agstc

# Gmail App Password for sending verification emails
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_gmail_app_password

# Optional: YouTube Data API key for faster sermon sync
# Without this, the keyless scraper is used automatically
YOUTUBE_API_KEY=
