# =====================================================================
# AGSTC Church Website — Environment Variables Template
# =====================================================================
# Copy this file to backend/.env and fill in your actual values.
# NEVER commit the real .env file to Git (it is already in .gitignore).
# On Hostinger: set these in hPanel → Node.js → Environment Variables
# =====================================================================

# --- Server ---
PORT=3000
NODE_ENV=production

# --- Auth ---
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# --- YouTube Sync (for sermon auto-sync) ---
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here

# --- Email / Contact Form (Nodemailer) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@agstc.org
SMTP_PASS=your_email_password_here
CONTACT_RECEIVER=info@agstc.org
